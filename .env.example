# ─── 1GigLabs Insight Generator — Environment Variables ──────────────────────
# Copy this file to .env and fill in values for local development.
# In Railway: set these in the Variables tab of your service.

# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/database

# Session secret — generate a random 32+ char string
SESSION_SECRET=change-me-to-a-random-32-char-string

# Resend API key — get from resend.com
RESEND_API_KEY=re_...

# Your app's public URL — used in email verification/reset links
# Set to your Railway domain or custom domain
APP_URL=https://your-domain.up.railway.app

# ── Optional ──────────────────────────────────────────────────────────────────

# Port — Railway sets this automatically ($PORT)
PORT=3000
